{
  "name": "notion-sync-vscode",
  "displayName": "Notion Sync",
  "description": "Sync Notion pages and databases to Markdown files",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --format=cjs --platform=node --external:vscode"
  },
  "contributes": {
    "commands": [
      {
        "command": "notionSync.sync",
        "title": "Notion Sync: Sync Page or Database"
      },
      {
        "command": "notionSync.resync",
        "title": "Notion Sync: Re-sync Current File"
      }
    ],
    "configuration": {
      "title": "Notion Sync",
      "properties": {
        "notionSync.apiKey": {
          "type": "string",
          "default": "",
          "description": "Notion API integration token"
        },
        "notionSync.defaultOutputFolder": {
          "type": "string",
          "default": "notion",
          "description": "Default folder for synced Markdown files (relative to workspace root)"
        }
      }
    }
  },
  "dependencies": {
    "@notion-sync/core": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0"
  }
}
